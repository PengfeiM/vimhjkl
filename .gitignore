# Python bytecode
__pycache__/
*.py[cod]

# Virtual environment
.venv/

# Secrets — never commit API keys
.env
.env.*

# Player state — local, never committed
progress.json
config.json

# Build intermediates — local only. The build system (build/) and the verified
# instance pool (content/llm_pool.json) ARE tracked so anyone can rebuild
# skills.json; the reading cursor and reject log stay local.
content/build_state.json
content/llm_rejects.json
build/cursor.py

# Local tooling / reference material — not distributed
.claude/
source-material.md
CLAUDE.md
